#!/usr/bin/env bash
set -euo pipefail

# Ensure ~/go/bin is on PATH (for goimports, golangci-lint)
export PATH="$HOME/go/bin:$PATH"

# ── Pre-commit hook ──────────────────────────────────────────────────────────
#   Backend  → goimports + golangci-lint
#   Frontend → prettier + eslint (via lint-staged)
# ─────────────────────────────────────────────────────────────────────────────

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
STAGED_FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '^frontend/' || true)

# ── Backend: Go ──────────────────────────────────────────────────────────────
if [ -n "$STAGED_GO_FILES" ]; then
    echo "━━━ 🐹 Go: format + lint ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Format with goimports (includes gofmt)
    if command -v goimports &>/dev/null; then
        echo "  Formatting staged Go files..."
        for f in $STAGED_GO_FILES; do
            goimports -w "$f" && git add "$f"
        done
        echo "  ✓ goimports"
    else
        echo "  ⚠ goimports not found — skipping format"
    fi

    # Lint with golangci-lint (only new issues)
    if command -v golangci-lint &>/dev/null; then
        echo "  Linting backend..."
        cd backend
        golangci-lint run --new-from-rev=HEAD~1 ./...
        cd ..
        echo "  ✓ golangci-lint"
    else
        echo "  ⚠ golangci-lint not found — skipping lint"
    fi
    echo ""
fi

# ── Frontend: Prettier + ESLint ──────────────────────────────────────────────
if [ -n "$STAGED_FRONTEND_FILES" ]; then
    echo "━━━ 📦 Frontend: prettier + eslint ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    cd frontend
    pnpm lint-staged
    cd ..
    echo ""
fi

echo "━━━ ✅ Pre-commit checks passed ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
