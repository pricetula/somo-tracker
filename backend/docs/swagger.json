{
    "swagger": "2.0",
    "info": {
        "description": "REST API for the Somotracker educational analytics platform.",
        "title": "Somotracker API",
        "contact": {
            "name": "Somotracker Team"
        },
        "license": {
            "name": "Proprietary"
        },
        "version": "0.1.0"
    },
    "host": "localhost:3030",
    "basePath": "/",
    "paths": {
        "/api/auth/callback": {
            "get": {
                "description": "Stytch redirects users here after clicking a magic link. Verifies the token, caches the IST, and redirects to the frontend.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Magic-link callback",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Stytch discovery magic link token",
                        "name": "token",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "302": {
                        "description": "Redirects to frontend /register with session_ref"
                    },
                    "422": {
                        "description": "Invalid input",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    }
                }
            }
        },
        "/api/auth/discover": {
            "post": {
                "description": "Sends a magic-link email to the given address to discover or create an organization.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Initiate magic-link discovery",
                "parameters": [
                    {
                        "description": "Email address to send magic link to",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth.DiscoveryPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Magic link sent"
                    },
                    "422": {
                        "description": "Invalid input",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    }
                }
            }
        },
        "/api/auth/me": {
            "get": {
                "description": "Returns the authenticated user's ID and tenant ID from the session cookie.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Get current session",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.MeResponse"
                        }
                    },
                    "401": {
                        "description": "Session expired or missing",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    }
                }
            }
        },
        "/api/auth/register": {
            "post": {
                "description": "Creates a tenant (school), user, and session. Sets the session cookie on success.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Complete registration",
                "parameters": [
                    {
                        "description": "Registration details",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth.RegistrationPayload"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Session cookie set; no content"
                    },
                    "401": {
                        "description": "Token expired or MFA required",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "409": {
                        "description": "Organization already exists",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "422": {
                        "description": "Invalid input",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    }
                }
            }
        },
        "/api/auth/session": {
            "delete": {
                "description": "Destroys the current session and clears cookies.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Logout",
                "responses": {
                    "204": {
                        "description": "Session destroyed; cookies cleared"
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    }
                }
            }
        },
        "/api/auth/verify": {
            "post": {
                "description": "Validates a magic-link discovery token and returns a session reference for the registration flow.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Verify magic-link token",
                "parameters": [
                    {
                        "description": "Magic link token",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth.VerifyPayload"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.VerifyResponse"
                        }
                    },
                    "401": {
                        "description": "Token expired",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "422": {
                        "description": "Invalid input",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_auth.ErrorBody"
                        }
                    }
                }
            }
        },
        "/tenants": {
            "post": {
                "description": "Creates a new tenant (school) in the system.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Tenants"
                ],
                "summary": "Create a tenant",
                "parameters": [
                    {
                        "description": "Tenant details",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_tenant.CreateTenantPayload"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal_tenant.Tenant"
                        }
                    },
                    "422": {
                        "description": "Invalid input",
                        "schema": {
                            "$ref": "#/definitions/internal_tenant.ErrorBody"
                        }
                    },
                    "500": {
                        "description": "Internal error",
                        "schema": {
                            "$ref": "#/definitions/internal_tenant.ErrorBody"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_auth.DiscoveryPayload": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string"
                }
            }
        },
        "internal_auth.ErrorBody": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "internal_auth.MeResponse": {
            "type": "object",
            "properties": {
                "tenant_id": {
                    "type": "string"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "internal_auth.RegistrationPayload": {
            "type": "object",
            "properties": {
                "first_name": {
                    "type": "string"
                },
                "last_name": {
                    "type": "string"
                },
                "school_name": {
                    "type": "string"
                },
                "session_ref": {
                    "type": "string"
                }
            }
        },
        "internal_auth.VerifyPayload": {
            "type": "object",
            "properties": {
                "token": {
                    "type": "string"
                }
            }
        },
        "internal_auth.VerifyResponse": {
            "type": "object",
            "properties": {
                "session_ref": {
                    "type": "string"
                }
            }
        },
        "internal_tenant.CreateTenantPayload": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "slug": {
                    "type": "string"
                }
            }
        },
        "internal_tenant.ErrorBody": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "internal_tenant.Tenant": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "slug": {
                    "type": "string"
                }
            }
        }
    },
    "tags": [
        {
            "description": "Authentication and session management endpoints",
            "name": "Auth"
        },
        {
            "description": "Tenant (school) management endpoints",
            "name": "Tenants"
        }
    ]
}