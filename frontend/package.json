{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "generate:api": "openapi-typescript ../backend/docs/swagger.json --output src/lib/api/generated.ts",
        "generate:api:dev": "openapi-typescript http://localhost:3030/swagger/doc.json --output src/lib/api/generated.ts",
        "audit:docs": "node scripts/audit-docs.js"
    },
    "dependencies": {
